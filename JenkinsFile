pipeline {
    agent {
        docker {
            image 'python:3.10'
        }
    }

    stages {

        stage('Install Dependencies') {
            steps {
                sh '''
                export HOME=/tmp
                export PATH=$HOME/.local/bin:$PATH
                pip install --user -r requirements.txt
                '''
            }
        }

        stage('Run Tests') {
            steps {
                sh '''
                export HOME=/tmp
                export PATH=$HOME/.local/bin:$PATH
                pytest
                '''
            }
        }

        stage('Run App') {
            steps {
                sh 'python app.py'
            }
        }
    }
}
