pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "niralibhangale/python-app"
    }

    stages {

        stage('Clone Code') {
            steps {
                git 'https://github.com/niralibhangale/CICD-pipeline-using-a-Python-app-GitHub-Actions.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'pip install -r requirements.txt'
            }
        }

        stage('Run Tests') {
            steps {
                sh 'pytest'
            }
        }

        stage('Push Image') {
            steps {
                sh 'docker push $DOCKER_IMAGE'
            }
        }
    }
}
